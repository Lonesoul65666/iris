# Copy to .env.local (gitignored) and fill in. Keys without a VITE_ prefix stay
# server-side and never reach the client bundle.

# Postgres connection string (Supabase Session Pooler URI, port 5432). Lets the
# backend auto-connect at boot — no browser localStorage paste needed.
# postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Teller mTLS client cert + private key (ABSOLUTE paths; the files live OUTSIDE
# the repo and are never committed). DEPRECATED — Teller shut down its API in
# 2026; kept only so old connectors still read until the Plaid cutover.
TELLER_CERT_PATH=
TELLER_KEY_PATH=
TELLER_ENV=development

# Plaid — bank/card transaction sync (Teller's replacement). client_id is an
# identifier; the secret is the real credential (never commit it). PLAID_ENV
# selects which Plaid environment + secret you're using.
#   PLAID_ENV=sandbox     build/test with fake banks (secret = Sandbox secret)
#   PLAID_ENV=production   real banks (secret = Production secret)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Auto-sync: the always-on host pulls Plaid every N hours so bank data stays
# fresh without anyone clicking refresh. Default 12. Set to 0 to disable.
# PLAID_AUTOSYNC_HOURS=12

# Gemini API key for the intelligence/LLM features (client-side, hence VITE_).
# NOTE: for a hosted setup you can skip this — the key you enter in-app is
# stored in the database and travels with it, so a new host picks it up for free.
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ── Hosting (self-hosted / Tailscale) ────────────────────────────────────────
# Port to listen on (default 5173).
# PORT=5173
#
# IRIS_LAN=1 binds all interfaces (0.0.0.0) so the app is reachable off this
# machine — required for Tailscale/remote access. SAFETY: the server REFUSES a
# wide bind until you've created login accounts (first-run setup), so you can't
# accidentally expose an unauthenticated instance. Leave unset for loopback-only.
# IRIS_LAN=1
